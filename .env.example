# ─── Agency OS — Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in all values before starting.
# Never commit .env to version control.

# ─── Database ─────────────────────────────────────────────────────────────────
# Strong random password: openssl rand -base64 32
POSTGRES_PASSWORD=change_me_strong_password

# In Docker: uses service name "db" as host
DATABASE_URL=postgresql://app:change_me_strong_password@db:5432/app
# Outside Docker (local Prisma Studio etc.): use localhost
# DATABASE_URL=postgresql://app:change_me_strong_password@localhost:5432/app

# ─── Redis ────────────────────────────────────────────────────────────────────
# Strong random password: openssl rand -base64 32
REDIS_PASSWORD=change_me_redis_password

# In Docker: uses service name "redis" as host
REDIS_URL=redis://:change_me_redis_password@redis:6379
# Outside Docker: REDIS_URL=redis://:change_me_redis_password@localhost:6379

# ─── Auth (NextAuth.js) ───────────────────────────────────────────────────────
# Minimum 32 chars: openssl rand -base64 32
NEXTAUTH_SECRET=change_me_minimum_32_chars_nextauth_secret_here

# The URL users access the app from
NEXTAUTH_URL=http://localhost:3000
# Production: NEXTAUTH_URL=https://agency-os.yourdomain.com

# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=production
INTERNAL_API_KEY=change_me_internal_api_key_min_24_chars
N8N_WEBHOOK_PROPOSAL_URL=
N8N_WEBHOOK_INVOICE_URL=
N8N_WEBHOOK_YEARLY_REPORT_URL=
N8N_WEBHOOK_MONTHLY_REPORT_URL=

# ─── GitHub ───────────────────────────────────────────────────────────────────
# Optional for GitHub features in the project workspace.
# Use a Personal Access Token with access to the repos you want to read/write.
GITHUB_TOKEN=

# ─── Seed admin user ──────────────────────────────────────────────────────────
# Used during `npm run db:seed` or by the one-off migrate container on first boot
SEED_ADMIN_EMAIL=admin@yourcompany.nl
SEED_ADMIN_PASSWORD=change_me_admin_password
SEED_ADMIN_NAME=Admin
SEED_DEMO_DATA=true
