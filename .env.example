# ══════════════════════════════════════
# DATABASE
# ══════════════════════════════════════
POSTGRES_DB=ticketsystem
POSTGRES_USER=ticketsystem
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
DB_PORT=5432

# ══════════════════════════════════════
# REDIS
# ══════════════════════════════════════
REDIS_PASSWORD=CHANGE_ME_strong_redis_password
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
REDIS_PORT=6379

# ══════════════════════════════════════
# APPLICATION
# ══════════════════════════════════════
APP_ENV=development
# APP_ENV=production
APP_NAME=Accuro
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ══════════════════════════════════════
# SECURITY — JWT
# ══════════════════════════════════════
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE_ME_generate_with_secrets_token_urlsafe_64
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ══════════════════════════════════════
# SECURITY — CORS
# ══════════════════════════════════════
# Comma-separated origins, no wildcard
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ══════════════════════════════════════
# SECURITY — RATE LIMITING
# ══════════════════════════════════════
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_EXTERNAL_API=30/minute
RATE_LIMIT_GENERAL=200/minute

# ══════════════════════════════════════
# EXTERNAL API
# ══════════════════════════════════════
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
EXTERNAL_API_KEY=CHANGE_ME_generate_with_secrets_token_urlsafe_32

# ══════════════════════════════════════
# INTEGRATIONS (optional)
# ══════════════════════════════════════
GITHUB_TOKEN=
DISCORD_TICKET_WEBHOOK_URL=

# ══════════════════════════════════════
# SEED DATA
# ══════════════════════════════════════
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=CHANGE_ME_min_12_chars_1Upper_1Lower_1Digit_1Special!
SEED_ADMIN_NAME=Admin

# Bedrijfsinstellingen — worden éénmalig in de DB gezet als die nog leeg is.
# Daarna via de UI te wijzigen. Nooit in git opslaan.
SEED_COMPANY_NAME=
SEED_COMPANY_EMAIL=
SEED_COMPANY_PHONE=
SEED_COMPANY_STREET=
SEED_COMPANY_POSTAL_CODE=
SEED_COMPANY_CITY=
SEED_COMPANY_WEBSITE=
SEED_COMPANY_KVK=
SEED_COMPANY_VAT=
SEED_COMPANY_IBAN=
SEED_COMPANY_ACCOUNT_HOLDER=

# ══════════════════════════════════════
# OAUTH / OIDC PROVIDER
# ══════════════════════════════════════
# Publieke URL van Accuro (basis voor OIDC discovery en token issuer)
OAUTH_ISSUER=https://accuro.yourdomain.nl
# RSA-2048 private key (PEM). Genereer met: openssl genrsa 2048
# Leeg laten in development — dan wordt automatisch een ephemeral key gegenereerd (niet voor productie!)
OAUTH_RSA_PRIVATE_KEY=
# Seed een OIDC client bij opstarten (éénmalig, sla op als record al bestaat)
SEED_OAUTH_CLIENT_ID=launchpad
SEED_OAUTH_CLIENT_SECRET=CHANGE_ME_generate_with_secrets_token_urlsafe_32
SEED_OAUTH_CLIENT_NAME=Launchpad
SEED_OAUTH_REDIRECT_URI=https://launchpad.yourdomain.nl/auth/callback

# ══════════════════════════════════════
# FRONTEND
# ══════════════════════════════════════
VITE_API_URL=http://localhost:8000
