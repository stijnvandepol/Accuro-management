# Database
POSTGRES_PASSWORD=change_me_strong_password

# Redis
REDIS_PASSWORD=change_me_redis_password

# App
DATABASE_URL=postgresql://webvakwerk:change_me_strong_password@db:5432/webvakwerk
REDIS_URL=redis://:change_me_redis_password@redis:6379

# JWT
JWT_SECRET=change_me_minimum_32_chars_jwt_secret_key_here
REFRESH_TOKEN_SECRET=change_me_minimum_32_chars_refresh_secret_here
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# App
NEXTAUTH_URL=https://your-domain.com
NODE_ENV=production

# Upload limits
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=/app/uploads

# Optional: Seed admin user on first run
SEED_ADMIN_EMAIL=admin@webvakwerk.nl
SEED_ADMIN_PASSWORD=change_me_admin_password
SEED_ADMIN_NAME=Admin
