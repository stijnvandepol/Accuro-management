# Lightweight migration + seed runner.
# Runs once at startup: deploys migrations, seeds if DB is empty, then exits.
FROM node:22-alpine

WORKDIR /app

RUN apk add --no-cache libc6-compat

COPY package*.json ./
COPY prisma/ ./prisma/

# Install all deps (prisma CLI + tsx + bcryptjs needed for seed)
RUN npm ci && npx prisma generate

COPY scripts/migrate-and-seed.sh ./scripts/

CMD ["sh", "scripts/migrate-and-seed.sh"]
