generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ─────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(DEVELOPER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens       RefreshToken[]
  assignedTickets     Ticket[]              @relation("AssignedTickets")
  createdTickets      Ticket[]              @relation("CreatedTickets")
  archivedTickets     Ticket[]              @relation("ArchivedTickets")
  createdLeads        Lead[]                @relation("CreatedLeads")
  assignedLeads       Lead[]                @relation("AssignedLeads")
  createdProjects     Project[]             @relation("CreatedProjects")
  notifications       Notification[]
  activityLogs        ActivityLog[]
  apiKeys             ApiKey[]
  comments            TicketComment[]
  timelineEntries     TicketTimelineEntry[] @relation("TimelineAuthor")
  commEntries         CommunicationEntry[]  @relation("CommAuthor")
  referencesCreated   TicketReference[]     @relation("ReferenceCreator")
  wikiPagesCreated    WikiPage[]            @relation("WikiCreator")
  wikiEdits           WikiPageVersion[]     @relation("WikiEditor")
  wikiLinksCreated    TicketWikiLink[]      @relation("WikiLinkCreator")
  githubConnections   GitHubConnection[]    @relation("GitHubConnectionCreator")
  repoLinks           TicketRepositoryLink[] @relation("RepoLinkCreator")
  agentRunsStarted    AgentRun[]            @relation("AgentRunStarter")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  PROJECT_MANAGER
  DEVELOPER
  SALES
}

model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  family    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([family])           // deleteMany({ family }) on reuse detection
  @@index([userId])           // list all sessions for a user
  @@index([expiresAt])        // periodic cleanup of expired tokens
}

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  keyHash     String    @unique
  keyPrefix   String
  scopes      String[]
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([createdById])      // list API keys by owner
  @@index([expiresAt])        // periodic expiry cleanup
}

// ─── Clients ──────────────────────────────────────────────────────────────────

model Client {
  id          String    @id @default(cuid())
  name        String
  companyName String?
  email       String?
  phone       String?
  website     String?
  notes       String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  contacts ClientContact[]
  leads    Lead[]
  projects Project[]
  tickets  Ticket[]
}

model ClientContact {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  phone     String?
  role      String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tickets Ticket[]
}

// ─── Leads ────────────────────────────────────────────────────────────────────

model Lead {
  id                   String     @id @default(cuid())
  title                String
  status               LeadStatus @default(NEW_REQUEST)
  clientId             String?
  client               Client?    @relation(fields: [clientId], references: [id])
  contactName          String?
  contactEmail         String?
  contactPhone         String?
  companyName          String?
  description          String?
  source               String?
  estimatedValue       Decimal?   @db.Decimal(10, 2)
  notes                String?
  createdById          String
  createdBy            User       @relation("CreatedLeads", fields: [createdById], references: [id])
  assignedToId         String?
  assignedTo           User?      @relation("AssignedLeads", fields: [assignedToId], references: [id])
  convertedToProjectId String?    @unique
  convertedToProject   Project?   @relation("ConvertedFromLead")
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  deletedAt            DateTime?

  @@index([status])
  @@index([assignedToId])
}

enum LeadStatus {
  NEW_REQUEST
  INTAKE_IN_PROGRESS
  INTAKE_COMPLETE
  DEMO_SCHEDULED
  DEMO_IN_PROGRESS
  DEMO_50_READY
  WAITING_FOR_RESPONSE
  APPROVAL_RECEIVED
  REJECTED
  WAITING_FOR_PAYMENT
  PAID
  CONVERTED_TO_PROJECT
}

// ─── Projects ─────────────────────────────────────────────────────────────────

model Project {
  id                 String         @id @default(cuid())
  title              String
  description        String?
  status             ProjectStatus  @default(KICKOFF)
  packageType        PackageType    @default(BASIS)
  clientId           String
  client             Client         @relation(fields: [clientId], references: [id])
  leadId             String?        @unique
  lead               Lead?          @relation("ConvertedFromLead", fields: [leadId], references: [convertedToProjectId])
  createdById        String
  createdBy          User           @relation("CreatedProjects", fields: [createdById], references: [id])
  assignedToId       String?
  approvalStatus     ApprovalStatus @default(PENDING)
  paymentStatus      PaymentStatus  @default(UNPAID)
  feedbackRoundsUsed Int            @default(0)
  startDate          DateTime?
  targetDeadline     DateTime?
  goLiveDate         DateTime?
  deliverables       String[]
  notes              String?
  isActive           Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  deletedAt          DateTime?

  tickets        Ticket[]
  feedbackRounds FeedbackRound[]
}

enum ProjectStatus {
  KICKOFF
  IN_DEVELOPMENT
  WAITING_FOR_INPUT
  FEEDBACK_RECEIVED
  FEEDBACK_ROUND_1
  FEEDBACK_ROUND_2
  FEEDBACK_ROUND_3
  FEEDBACK_ROUND_4
  REVISION_IN_PROGRESS
  READY_FOR_DELIVERY
  GO_LIVE_SCHEDULED
  LIVE
  HANDED_OVER
  COMPLETED
  ON_HOLD
  CANCELLED
}

enum PackageType {
  BASIS
  PREMIUM
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

enum PaymentStatus {
  UNPAID
  INVOICE_SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  REFUNDED
}

// ─── Tickets ──────────────────────────────────────────────────────────────────

model Ticket {
  id             String       @id @default(cuid())
  ticketNumber   String       @unique
  title          String
  description    String?
  status         TicketStatus @default(OPEN)
  priority       Priority     @default(MEDIUM)
  type           TicketType   @default(TASK)
  category       String?
  source         TicketSource @default(MANUAL)
  clientId       String?
  client         Client?      @relation(fields: [clientId], references: [id])
  clientContactId String?
  clientContact  ClientContact? @relation(fields: [clientContactId], references: [id])
  projectId      String?
  project        Project?     @relation(fields: [projectId], references: [id])
  assignedToId   String?
  assignedTo     User?        @relation("AssignedTickets", fields: [assignedToId], references: [id])
  labels         String[]
  dueDate        DateTime?
  estimatedHours Decimal?     @db.Decimal(6, 2)
  isExtraWork    Boolean      @default(false)
  approvalStatus TicketApprovalStatus @default(NOT_REQUIRED)
  paymentStatus  TicketPaymentStatus  @default(NOT_APPLICABLE)
  createdById    String
  createdBy      User         @relation("CreatedTickets", fields: [createdById], references: [id])
  archivedById   String?
  archivedBy     User?        @relation("ArchivedTickets", fields: [archivedById], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  archivedAt     DateTime?
  deletedAt      DateTime?
  version        Int          @default(1)

  comments          TicketComment[]
  attachments       Attachment[]
  timelineEntries   TicketTimelineEntry[]
  communications    CommunicationEntry[]
  references        TicketReference[]
  wikiLinks         TicketWikiLink[]
  repositoryLinks   TicketRepositoryLink[]
  agentRuns         AgentRun[]

  @@index([status])
  @@index([assignedToId])
  @@index([clientId])
  @@index([projectId])
  @@index([priority])
  @@index([createdAt])
  @@index([dueDate])
  @@index([deletedAt])
  @@index([archivedAt])
  @@index([deletedAt, status, createdAt])
  @@index([assignedToId, status, dueDate])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_FOR_CLIENT
  APPROVAL_PENDING
  WAITING_FOR_PAYMENT
  FEEDBACK_REQUESTED
  IN_REVIEW
  DONE
  CANCELLED
  ON_HOLD
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketType {
  TASK
  BUG
  FEEDBACK
  FEATURE
  QUESTION
  INTAKE
}

enum TicketSource {
  MANUAL
  API
  AUTOMATION
  COMMUNICATION
  GITHUB
  OTHER
}

enum TicketApprovalStatus {
  NOT_REQUIRED
  PENDING
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

enum TicketPaymentStatus {
  NOT_APPLICABLE
  UNPAID
  INVOICE_SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  REFUNDED
}

// ─── Feedback Rounds ──────────────────────────────────────────────────────────

model FeedbackRound {
  id          String              @id @default(cuid())
  projectId   String
  project     Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  roundNumber Int
  status      FeedbackRoundStatus @default(OPEN)
  notes       String?
  isExtraWork Boolean             @default(false)
  openedAt    DateTime            @default(now())
  closedAt    DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([projectId, roundNumber])  // prevent duplicate round numbers per project
}

enum FeedbackRoundStatus {
  OPEN
  IN_PROGRESS
  CLOSED
  EXTRA_WORK
}

// ─── Comments ─────────────────────────────────────────────────────────────────

model TicketComment {
  id         String    @id @default(cuid())
  ticketId   String
  ticket     Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId   String
  author     User      @relation(fields: [authorId], references: [id])
  body       String
  isInternal Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  attachments Attachment[]
}

// ─── Attachments ──────────────────────────────────────────────────────────────

model Attachment {
  id           String         @id @default(cuid())
  filename     String
  storagePath  String
  mimeType     String
  sizeBytes    Int
  ticketId     String?
  ticket       Ticket?        @relation(fields: [ticketId], references: [id])
  commentId    String?
  comment      TicketComment? @relation(fields: [commentId], references: [id])
  uploadedById String
  createdAt    DateTime       @default(now())
}

// ─── Status History ───────────────────────────────────────────────────────────

// StatusHistory uses entityType + entityId as a polymorphic key (plain string, no FK).
// Enforcing referential integrity per entity type in application code is simpler and
// avoids the PostgreSQL limitation of a single column referencing multiple tables.
model StatusHistory {
  id          String   @id @default(cuid())
  entityType  String
  entityId    String
  fromStatus  String?
  toStatus    String
  changedById String
  reason      String?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([changedById])
}

// ─── Audit / Activity Log ─────────────────────────────────────────────────────

// ActivityLog also uses a polymorphic entityType + entityId (plain string, no FK).
model ActivityLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])        // dashboard recent activity query
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       NotificationType
  title      String
  body       String?
  entityType String?
  entityId   String?
  isRead     Boolean          @default(false)
  readAt     DateTime?
  createdAt  DateTime         @default(now())
}

enum NotificationType {
  NEW_LEAD
  NEW_TICKET
  TICKET_ASSIGNED
  STATUS_CHANGED
  FEEDBACK_RECEIVED
  APPROVAL_RECEIVED
  PAYMENT_STATUS_CHANGED
  DEADLINE_APPROACHING
  PROJECT_COMPLETED
  COMMENT_ADDED
  FEEDBACK_ROUND_EXCEEDED
}

// ─── Timeline ────────────────────────────────────────────────────────────────

model TicketTimelineEntry {
  id           String            @id @default(cuid())
  ticketId     String
  ticket       Ticket            @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  type         TimelineEntryType
  authorId     String?
  author       User?             @relation("TimelineAuthor", fields: [authorId], references: [id])
  content      String?           // markdown for NOTE, null for system events
  metadata     Json?             // flexible: { oldStatus, newStatus } etc.
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  deletedAt    DateTime?         // soft delete for NOTE entries only

  @@index([ticketId, createdAt])
  @@index([ticketId, type])
}

enum TimelineEntryType {
  NOTE
  SYSTEM_EVENT
  STATUS_CHANGE
  ASSIGNMENT
  REFERENCE_ADDED
  REFERENCE_REMOVED
  WIKI_LINKED
  WIKI_UNLINKED
  GITHUB_LINKED
  AGENT_RUN_STARTED
  AGENT_RUN_COMPLETED
  COMMUNICATION_LINKED
}

// ─── Communications ───────────────────────────────────────────────────────────

model CommunicationEntry {
  id                String           @id @default(cuid())
  ticketId          String
  ticket            Ticket           @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  direction         CommDirection
  channel           CommChannel
  subject           String?
  body              String
  externalSender    String?
  authorId          String?
  author            User?            @relation("CommAuthor", fields: [authorId], references: [id])
  externalMessageId String?          @unique // idempotency / dedup
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  isImmutable       Boolean          @default(false)
  attachments       CommAttachment[]

  @@index([ticketId, createdAt])
  @@index([externalMessageId])
}

enum CommDirection {
  INCOMING
  OUTGOING
}

enum CommChannel {
  EMAIL
  MEETING
  CALL
  MESSAGE
  OTHER
}

model CommAttachment {
  id              String             @id @default(cuid())
  communicationId String
  communication   CommunicationEntry @relation(fields: [communicationId], references: [id], onDelete: Cascade)
  filename        String
  storagePath     String
  mimeType        String
  sizeBytes       Int
  createdAt       DateTime           @default(now())
}

// ─── References ───────────────────────────────────────────────────────────────

model TicketReference {
  id          String        @id @default(cuid())
  ticketId    String
  ticket      Ticket        @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  title       String
  url         String
  type        ReferenceType @default(OTHER)
  description String?
  createdById String
  createdBy   User          @relation("ReferenceCreator", fields: [createdById], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([ticketId])
}

enum ReferenceType {
  GITHUB
  FIGMA
  DOCS
  DEPLOYMENT
  MONITORING
  DRIVE
  NOTION
  OTHER
}

// ─── Wiki ─────────────────────────────────────────────────────────────────────

model WikiPage {
  id          String           @id @default(cuid())
  title       String
  slug        String           @unique
  content     String
  category    String?
  version     Int              @default(1)
  createdById String
  createdBy   User             @relation("WikiCreator", fields: [createdById], references: [id])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  versions    WikiPageVersion[]
  ticketLinks TicketWikiLink[]

  @@index([slug])
  @@index([category])
}

model WikiPageVersion {
  id         String   @id @default(cuid())
  pageId     String
  page       WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  content    String
  version    Int
  editedById String
  editedBy   User     @relation("WikiEditor", fields: [editedById], references: [id])
  createdAt  DateTime @default(now())

  @@index([pageId, version])
}

model TicketWikiLink {
  id          String   @id @default(cuid())
  ticketId    String
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  wikiPageId  String
  wikiPage    WikiPage @relation(fields: [wikiPageId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User     @relation("WikiLinkCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  @@unique([ticketId, wikiPageId])
  @@index([ticketId])
  @@index([wikiPageId])
}

// ─── GitHub Integration ───────────────────────────────────────────────────────

// Registered GitHub repository available for linking to tickets.
// One record per owner/repo pair. Created by an admin via the settings page.
// Uses installationId for GitHub App auth or a service-account reference.
model GitHubConnection {
  id             String    @id @default(cuid())
  provider       String    @default("github")
  installationId String?   // GitHub App installation ID (set if using GitHub App)
  owner          String    // e.g. "webvakwerk"
  repo           String    // e.g. "site-klant" — use "*" for org-level (all repos)
  defaultBranch  String    @default("main")
  encryptedToken String?   // AES-256-GCM encrypted PAT (null = no token stored)
  tokenSetAt     DateTime? // when token was last updated
  isActive       Boolean   @default(true)
  createdById    String
  createdBy      User      @relation("GitHubConnectionCreator", fields: [createdById], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  repositoryLinks TicketRepositoryLink[]

  @@unique([owner, repo])
  @@index([isActive])
}

// Explicit link between a ticket and a GitHub repo, with optional branch/issue/PR.
model TicketRepositoryLink {
  id                      String           @id @default(cuid())
  ticketId                String
  ticket                  Ticket           @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  githubConnectionId      String
  githubConnection        GitHubConnection @relation(fields: [githubConnectionId], references: [id])
  repoName                String?          // set when githubConnection.repo == "*" (org-level)
  linkedBranch            String?          // e.g. "feature/homepage-feedback"
  linkedIssueNumber       Int?             // e.g. 42
  linkedPullRequestNumber Int?             // e.g. 43
  environmentUrl          String?          // preview/staging URL
  createdById             String
  createdBy               User             @relation("RepoLinkCreator", fields: [createdById], references: [id])
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  agentRuns AgentRun[]

  @@unique([ticketId, githubConnectionId]) // one link per ticket-repo pair
  @@index([ticketId])
  @@index([githubConnectionId])
}

enum AgentRunType {
  PLAN            // analyse ticket and generate implementation plan
  CREATE_ISSUE    // create a GitHub issue from ticket context
  UPDATE_ISSUE    // update an existing GitHub issue
  PREPARE_CHANGES // prepare code change recommendations
  OPEN_PR_DRAFT   // open a draft PR on the linked branch
  RUN_CODE_AGENT  // full autonomous code-agent run (restricted permission)
}

enum AgentRunStatus {
  PENDING    // created, not yet dispatched
  QUEUED     // dispatched, waiting in queue
  RUNNING    // actively executing
  SUCCEEDED  // completed successfully
  FAILED     // completed with error
  CANCELLED  // cancelled by user
}

// Record of an agent execution started from a ticket.
// The core app is the orchestrator — actual execution happens in an external
// automation layer (n8n / custom worker) that calls back via the webhook.
model AgentRun {
  id               String               @id @default(cuid())
  ticketId         String
  ticket           Ticket               @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  repositoryLinkId String
  repositoryLink   TicketRepositoryLink @relation(fields: [repositoryLinkId], references: [id])
  runType          AgentRunType
  status           AgentRunStatus       @default(PENDING)
  startedById      String
  startedBy        User                 @relation("AgentRunStarter", fields: [startedById], references: [id])
  inputSnapshot    Json                 // sanitized copy of ticket context at dispatch time
  outputSummary    String?              // short human-readable result
  outputData       Json?                // structured output (issue URL, PR URL, plan, etc.)
  errorMessage     String?
  externalRunId    String?              // ID returned by the external automation system
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  completedAt      DateTime?

  events AgentRunEvent[]

  @@index([ticketId])
  @@index([repositoryLinkId])
  @@index([status])
  @@index([externalRunId])
}

// Fine-grained event log per agent run (progress updates, errors, sub-steps).
model AgentRunEvent {
  id         String   @id @default(cuid())
  agentRunId String
  agentRun   AgentRun @relation(fields: [agentRunId], references: [id], onDelete: Cascade)
  type       String   // e.g. "info", "warning", "error", "progress"
  message    String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([agentRunId, createdAt])
}
